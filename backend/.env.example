APP_NAME=AquaGuard AI
APP_ENV=development
DEBUG=true
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=aquaguard
STORAGE_ROOT=../storage
MAX_UPLOAD_SIZE_MB=500
MOCK_AI=true
YOLO_MODEL=yolo11n.pt
DETECTION_CONFIDENCE=0.35
DETECTION_FRAME_INTERVAL=3
YOLO_IMAGE_SIZE=416
TRACKER_MAX_DISTANCE_PIXELS=120
TRACKER_MAX_MISSED_FRAMES=15
MOVEMENT_THRESHOLD_PIXELS=8
INACTIVITY_WARNING_SECONDS=5
RISK_SAFE_MAX=40
RISK_DANGER_MIN=70
DANGER_PERSISTENCE_SECONDS=3
RISK_SMOOTHING_ALPHA=0.35
RISK_INACTIVITY_WEIGHT=80
SUDDEN_DOWNWARD_PIXELS=20
INTENSE_SPEED_PIXELS_PER_SECOND=180
LOW_SPEED_PIXELS_PER_SECOND=15
INCIDENT_CLIP_SECONDS=3
INCIDENT_CLIP_FPS=5
POSE_ENABLED=true
POSE_MODEL=yolo11n-pose.pt
POSE_FRAME_INTERVAL=6
POSE_CONFIDENCE=0.35
POSE_IMAGE_SIZE=416
LIVE_DETECTION_CONFIDENCE=0.25
LIVE_YOLO_IMAGE_SIZE=512
LIVE_DETECTION_FRAME_INTERVAL=1
LIVE_TRACKER_MAX_DISTANCE_PIXELS=160
LIVE_TRACKER_MAX_MISSED_FRAMES=24
LIVE_MOVEMENT_THRESHOLD_PIXELS=5
LIVE_INACTIVITY_WARNING_SECONDS=3
LIVE_RISK_DANGER_MIN=60
LIVE_DANGER_PERSISTENCE_SECONDS=1.5
LIVE_RISK_SMOOTHING_ALPHA=0.55
LIVE_POSE_FRAME_INTERVAL=8
LIVE_POSE_CONFIDENCE=0.25
LIVE_POSE_IMAGE_SIZE=416
LIVE_INCIDENT_COOLDOWN_SECONDS=30
LIVE_USE_BYTETRACK=true
YOLO_DEVICE=
TEMPORAL_MODEL_PATH=models/drowning_temporal.ts
TEMPORAL_SEQUENCE_LENGTH=16
TEMPORAL_ALERT_THRESHOLD=0.65
TEMPORAL_RISK_WEIGHT=45
AQUATIC_MODEL_ENABLED=true
AQUATIC_MODEL_PATH=models/aquaguard_aquatic_best.pt
AQUATIC_MODEL_CONFIDENCE=0.25
AQUATIC_MODEL_IMAGE_SIZE=416
AQUATIC_MODEL_FRAME_INTERVAL=6
AQUATIC_MODEL_ALERT_THRESHOLD=0.60
AQUATIC_MODEL_RISK_WEIGHT=55
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_ESCALATION_SECONDS=60
INCIDENT_RETENTION_HOURS=24
INCIDENT_CLEANUP_INTERVAL_SECONDS=300
