# This file contains examples only. Copy relevant values to a local .env file later.
# Never commit the real .env file.

APP_NAME=AquaGuard AI
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=aquaguard

STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=500
MOCK_AI=true

# Replace this value with a long random secret before authentication is enabled.
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
